{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/meta",     "dest": "/api/meta.js" },
    { "src": "/api/hubspot",  "dest": "/api/hubspot.js" },
    { "src": "/(.*)",         "dest": "/public/$1" }
  ]
}
